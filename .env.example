# Inner Beast Frontend Environment
# Copy this file to .env.local for local development.
# Add the Production values in Vercel Project Settings > Environment Variables.

# Local development
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
# NEXT_PUBLIC_USE_API_PROXY=false

# Production / Vercel
NEXT_PUBLIC_SITE_URL=https://innerbeast-chi.vercel.app
NEXT_PUBLIC_API_URL=https://backend.himalayanessenceltd.com/api
NEXT_PUBLIC_SOCKET_URL=https://backend.himalayanessenceltd.com

# Use true only on Vercel/Next server deployments when browser API calls
# should go through the same-origin /api proxy to avoid Chrome cookie issues.
# Keep false for Hostinger static export because static hosting cannot run Next API routes.
NEXT_PUBLIC_USE_API_PROXY=true

# Optional future production domain examples:
# NEXT_PUBLIC_SITE_URL=https://innerbeast.co.uk
# NEXT_PUBLIC_API_URL=https://api.innerbeast.co.uk/api
# NEXT_PUBLIC_SOCKET_URL=https://api.innerbeast.co.uk
